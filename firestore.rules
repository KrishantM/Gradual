rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is a recruiter
    function isRecruiter() {
      return exists(/databases/$(database)/documents/recruiters/$(request.auth.uid));
    }
    
    // Helper function to check if user can access recruiter data
    function canAccessRecruiterData() {
      return request.auth != null && (
        // User is accessing their own recruiter data
        (resource.data.uid == request.auth.uid) ||
        // User is accessing recruiter collection and is a recruiter
        (isRecruiter())
      );
    }
    
    // Helper function to get recruiter data
    function getRecruiterData() {
      return get(/databases/$(database)/documents/recruiters/$(request.auth.uid)).data;
    }
    
    // Helper function to check if student allows recruiter contact
    function studentAllowsRecruiterContact(studentId) {
      let studentData = get(/databases/$(database)/documents/users/$(studentId)).data;
      return studentData.allowRecruiterContact != false && studentData.isProfilePublic != false;
    }
    
    // Users can only read/write their own data
    // Recruiters can read limited student data if student allows it
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && 
                     isRecruiter() && 
                     studentAllowsRecruiterContact(userId) &&
                     resource.data.role == 'student';
      // Copilot Phase 1: sessions and undo tokens (server-written via Admin SDK; client never writes)
      match /copilot_sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /copilot_undo/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /copilot_state/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /copilot_conversations/{convId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /planner_events/{eventId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      // Server-only subcollections (Admin SDK only — deny all client access)
      match /copilot_pending/{docId} {
        allow read, write: if false;
      }
      match /path_state/{docId} {
        allow read, write: if false;
      }
      match /generated_pathways/{docId} {
        allow read, write: if false;
      }
    }
    
    // Recruiter profiles - only recruiters can access their own data
    match /recruiters/{recruiterId} {
      allow read, write: if request.auth != null && request.auth.uid == recruiterId;
      allow create: if request.auth != null && request.auth.uid == recruiterId;
    }
    
    // Recruiter shortlists - only the recruiter who created them can access
    match /recruiterShortlists/{shortlistId} {
      allow read, write: if request.auth != null && 
                            isRecruiter() && 
                            request.auth.uid == resource.data.recruiterId;
      allow create: if request.auth != null && 
                       isRecruiter() && 
                       request.auth.uid == request.resource.data.recruiterId;
    }
    
    // Recruiter contacts - recruiters can create, students can read their own
    match /recruiterContacts/{contactId} {
      allow read, write: if request.auth != null && 
                            isRecruiter() && 
                            request.auth.uid == resource.data.recruiterId;
      allow read: if request.auth != null && 
                     request.auth.uid == resource.data.studentId;
      allow create: if request.auth != null && 
                       isRecruiter() && 
                       request.auth.uid == request.resource.data.recruiterId;
    }
    
    // Recruiter analytics - only the recruiter can access their own analytics
    match /recruiterAnalytics/{analyticsId} {
      allow read, write: if request.auth != null && 
                            isRecruiter() && 
                            request.auth.uid == resource.data.recruiterId;
      allow create: if request.auth != null && 
                       isRecruiter() && 
                       request.auth.uid == request.resource.data.recruiterId;
    }
    
    // Users can only read/write their own todos
    match /todos/{todoId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // Users can only read/write their own applications
    match /applications/{applicationId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // Users can only read/write their own action items
    match /actionItems/{actionItemId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // Users can only read/write their own suggestions
    match /suggestions/{suggestionId} {
      allow read, write: if request.auth != null && request.auth.uid == suggestionId;
    }
    
    // Opportunities — auth required for read; write is server-only (Admin SDK)
    // Intentional decision: all app users must be authenticated; no unauthenticated discovery path exists
    match /opportunities/{opportunityId} {
      allow read: if request.auth != null;
    }

    // Waitlist — auth required; actual writes go via Admin SDK (defence-in-depth)
    match /waitlist/{waitlistId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if request.auth != null;
    }

    // Server-only collections — all access via Admin SDK; deny all client access
    match /consultingLeads/{docId} {
      allow read, write: if false;
    }
    match /recruiterAccessRequests/{docId} {
      allow read, write: if false;
    }
    match /opportunities_meta/{docId} {
      allow read, write: if false;
    }
    match /system_logs/{docId} {
      allow read, write: if false;
    }
  }
}